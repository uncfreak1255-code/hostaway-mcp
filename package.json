{
  "name": "hostaway-mcp",
  "version": "0.2.0",
  "description": "Read-only, hospitality-shaped MCP server for Hostaway",
  "homepage": "https://github.com/uncfreak1255-code/hostaway-mcp#readme",
  "bugs": {
    "url": "https://github.com/uncfreak1255-code/hostaway-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uncfreak1255-code/hostaway-mcp.git"
  },
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "bin": {
    "hostaway-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "hostaway",
    "claude",
    "codex",
    "vacation-rental",
    "hospitality"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "mcpName": "io.github.uncfreak1255-code/hostaway"
}
