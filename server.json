{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.uncfreak1255-code/hostaway",
  "description": "Read-only MCP server for Hostaway PMS \u2014 guest conversations, reservations, and listings",
  "repository": {
    "url": "https://github.com/uncfreak1255-code/hostaway-mcp",
    "source": "github"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "hostaway-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HOSTAWAY_ACCOUNT_ID",
          "description": "Your Hostaway account ID",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "HOSTAWAY_API_KEY",
          "description": "Your Hostaway API key (client secret)",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
